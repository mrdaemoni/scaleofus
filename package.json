{
  "name": "scaleofus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Scale of Us - small books about big machines and human scale.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && node scripts/prune-build-assets.mjs && node scripts/check-reader-build.mjs",
    "build:pages": "npm run build && node scripts/sync-pages.mjs",
    "check:reader": "node scripts/check-reader-build.mjs",
    "new:book": "node scripts/scaffold-book.mjs",
    "prepare:audio": "node scripts/prepare-book-audio.mjs",
    "render:sketches": "node scripts/render-remarkable-sketches.mjs",
    "render:mobile-drawings": "node scripts/generate-mobile-drawings.mjs",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource-variable/playwrite-ie": "^5.2.7",
    "astro": "^6.2.1"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
