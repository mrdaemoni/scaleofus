---
import Base from "../layouts/Base.astro";
import storyMarkdown from "../content/the-boy-who-tried-to-catch-the-wind.md?raw";
import storyTimings from "../content/story-timings.json";
import { formatTime, parseStoryMarkdown } from "../lib/story";

const duration = 885.54;
const chapters = parseStoryMarkdown(storyMarkdown, duration, storyTimings);
const chapterData = chapters.map(({ number, title, id, start }) => ({ number, title, id, start }));
const beatData = chapters.flatMap((chapter) =>
  chapter.beats.map(({ number, start, end }) => ({ number, start, end, chapter: chapter.number })),
);
const motionByBeat = [
  "wind", "card", "glow", "path", "glow", "trail", "tap", "stream", "pebble", "smoke",
  "flame", "glow", "wheel", "question", "clay", "sun", "pond", "ripple", "rain", "leaf",
  "garden", "sprout", "flower", "path", "windows", "mirrors", "card", "still", "wind", "sky",
  "fragments", "gifts", "breath", "map", "windows", "breath", "page", "wind",
];
const firstSketchBeat = 11;
const artForBeat = (number: number) => number <= firstSketchBeat
  ? `/images/wind-story/sketches/beat-${String(number).padStart(2, "0")}.svg`
  : `/images/wind-story/beats/beat-${String(number).padStart(2, "0")}.jpg`;
---

<Base
  title="The Boy Who Tried to Catch the Wind — Scale of Us"
  description="An immersive reading and listening experience about a boy, a machine, and the part of us no answer can hold."
  bodyClass="story-page"
>
  <div class="reading-progress" aria-hidden="true"><span data-reading-progress></span></div>

  <header class="story-nav" data-story-nav>
    <a class="wordmark" href="#top" aria-label="Scale of Us, back to the beginning">
      <span>Scale</span><i>of</i><span>Us</span>
    </a>
    <nav aria-label="Story links">
      <a href="#story">Read</a>
      <button type="button" data-nav-listen>Listen</button>
      <a href="/grown-ups/">For grown-ups</a>
    </nav>
  </header>

  <main data-story-app data-chapters={JSON.stringify(chapterData)} data-beats={JSON.stringify(beatData)}>
    <section class="story-cover" id="top" aria-labelledby="story-title">
      <div class="cover-art" aria-hidden="true">
        <img class="is-hand-sketch" src={artForBeat(1)} alt="" fetchpriority="high" />
      </div>
      <div class="cover-vignette" aria-hidden="true"></div>
      <div class="wind-script" aria-hidden="true">
        <i></i><i></i><i></i>
      </div>

      <div class="cover-copy">
        <p class="eyebrow">A Scale of Us story</p>
        <h1 id="story-title">The Boy Who Tried to Catch the Wind</h1>
        <p class="cover-intro">A story about a boy, a machine, and the part of us no answer can hold.</p>
        <div class="cover-actions">
          <a class="primary-action" href="#story">Enter the story <span aria-hidden="true">↓</span></a>
          <button class="listen-action" type="button" data-hero-play>
            <span class="round-play" aria-hidden="true">▶</span>
            <span><strong>Listen from the beginning</strong><small>{formatTime(duration)} · read aloud</small></span>
          </button>
        </div>
      </div>

      <p class="cover-note">11 original reMarkable sketches · 27 rose-gray studies · final art to come</p>
      <a class="scroll-cue" href="#story" aria-label="Scroll into the story"><span></span></a>
    </section>

    <div class="reader-shell" id="story">
      <aside class="chapter-rail" aria-label="Chapters">
        <div class="mountain-nav-art" aria-hidden="true">
          <span class="nav-cloud cloud-one"></span>
          <span class="nav-cloud cloud-two"></span>
          <span class="nav-cloud cloud-three"></span>
          <span class="mountain-face"></span>
          <span class="mountain-snow"></span>
          <span class="mountain-ridge ridge-one"></span>
          <span class="mountain-ridge ridge-two"></span>
          <span class="mountain-path path-one"></span>
          <span class="mountain-path path-two"></span>
          <span class="mountain-path path-three"></span>
          <span class="mountain-summit"></span>
        </div>
        <p>The climb</p>
        <ol>
          {chapters.map((chapter) => (
            <li>
              <a href={`#${chapter.id}`} data-chapter-link data-start={chapter.start}>
                <span>{chapter.numeral}</span>
                <em>{chapter.shortTitle}</em>
              </a>
            </li>
          ))}
        </ol>
      </aside>

      <div class="story-flow">
        {chapters.map((chapter) => (
          <section
            class={`story-chapter chapter-${chapter.number}`}
            id={chapter.id}
            data-chapter={chapter.number}
            data-start={chapter.start}
            aria-labelledby={`${chapter.id}-title`}
          >
            <header class="chapter-heading">
              <p>Chapter {chapter.numeral}</p>
              <h2 id={`${chapter.id}-title`}>{chapter.title}</h2>
              <div class={`chapter-mark mark-${chapter.number}`} aria-hidden="true">
                <i></i><i></i><i></i>
              </div>
            </header>

            <div class="chapter-beats">
              {chapter.beats.map((beat, beatIndex) => {
                const motion = motionByBeat[beat.number - 1] ?? "drift";
                return (
                  <article
                    class="story-beat has-featured-art"
                    id={`beat-${beat.number}`}
                    data-beat={beat.number}
                    data-start={beat.start}
                    data-end={beat.end}
                  >
                    <figure class="beat-visual">
                      <div
                        class={`beat-art-frame ${beat.number <= firstSketchBeat ? "is-original-sketch" : ""}`}
                        data-cinematic-art
                        data-motion={motion}
                      >
                        <img
                          class={beat.number <= firstSketchBeat ? "is-hand-sketch" : undefined}
                          src={artForBeat(beat.number)}
                          alt={`Drawing ${beat.number}: ${beat.prompt}`}
                          loading={beat.number === 1 ? "eager" : "lazy"}
                        />
                        <div class={`cinematic-layer motion-${motion}`} aria-hidden="true">
                          {[1, 2, 3, 4, 5].map((mark) => <i class={`motion-mark mark-${mark}`}></i>)}
                        </div>
                      </div>
                      <figcaption>
                        <span>Drawing {String(beat.number).padStart(2, "0")}</span>
                        <span>{beat.number <= firstSketchBeat ? "original reMarkable sketch" : "rose-gray ink study"}</span>
                      </figcaption>
                    </figure>

                    <div class="beat-copy">
                      <p class="beat-number" aria-hidden="true">{String(beat.number).padStart(2, "0")}</p>
                      {beat.paragraphs.map((paragraph, paragraphIndex) => (
                        <p class={beatIndex === 0 && paragraphIndex === 0 ? "opening-line" : undefined}>{paragraph}</p>
                      ))}
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        ))}

        <section class="story-after" aria-labelledby="after-title">
          <p class="eyebrow">The story keeps company</p>
          <h2 id="after-title">There is another room for grown-ups.</h2>
          <p>Nine short notes trace the old ideas underneath the boy’s climb. They are companions to the story, not a key to it.</p>
          <a class="primary-action light" href="/grown-ups/">Enter the grown-ups room <span aria-hidden="true">→</span></a>
          <a class="return-link" href="#top">Return to the first hill</a>
        </section>
      </div>
    </div>
  </main>

  <div class="audio-dock" data-audio-dock>
    <audio
      data-audio
      src="/audio/the-boy-who-tried-to-catch-the-wind.mp3"
      preload="metadata"
    ></audio>
    <button class="dock-play" type="button" data-play aria-label="Play narration">
      <span data-play-icon aria-hidden="true">▶</span>
    </button>
    <div class="dock-now">
      <small>Now in the story</small>
      <strong data-current-chapter>Chapter I · The Boy Who Tried to Catch the Wind</strong>
    </div>
    <div class="dock-track">
      <div class="waveform" aria-hidden="true"></div>
      <input
        type="range"
        min="0"
        max={duration}
        value="0"
        step="0.1"
        data-seek
        aria-label="Narration position"
      />
      <div class="dock-time"><span data-current-time>0:00</span><span>{formatTime(duration)}</span></div>
    </div>
    <button class="follow-toggle" type="button" data-follow aria-pressed="true">
      <span aria-hidden="true"></span> Follow the voice
    </button>
    <button class="dock-collapse" type="button" data-collapse aria-label="Minimize audio player" aria-expanded="true">⌄</button>
  </div>

  <script>
    const app = document.querySelector<HTMLElement>("[data-story-app]");
    const audio = document.querySelector<HTMLAudioElement>("[data-audio]");
    const dock = document.querySelector<HTMLElement>("[data-audio-dock]");
    const playButtons = document.querySelectorAll<HTMLButtonElement>("[data-play], [data-hero-play], [data-nav-listen]");
    const dockPlay = document.querySelector<HTMLButtonElement>("[data-play]");
    const playIcon = document.querySelector<HTMLElement>("[data-play-icon]");
    const seek = document.querySelector<HTMLInputElement>("[data-seek]");
    const currentTime = document.querySelector<HTMLElement>("[data-current-time]");
    const currentChapter = document.querySelector<HTMLElement>("[data-current-chapter]");
    const follow = document.querySelector<HTMLButtonElement>("[data-follow]");
    const collapse = document.querySelector<HTMLButtonElement>("[data-collapse]");
    const readingProgress = document.querySelector<HTMLElement>("[data-reading-progress]");
    const chapters = JSON.parse(app?.dataset.chapters ?? "[]");
    const beats = JSON.parse(app?.dataset.beats ?? "[]");
    const chapterElements = [...document.querySelectorAll<HTMLElement>("[data-chapter]")];
    const chapterLinks = [...document.querySelectorAll<HTMLAnchorElement>("[data-chapter-link]")];
    const beatElements = [...document.querySelectorAll<HTMLElement>("[data-beat]")];
    const cinematicFrames = [...document.querySelectorAll<HTMLElement>("[data-cinematic-art]")];
    let activeChapter = 0;
    let activeBeat = -1;
    let followNarration = true;
    let lastAutoScrolledBeat = -1;
    let suppressScrollSeekUntil = 0;
    let lastUserScrollIntent = 0;
    let scrollSeekFrame = 0;
    let cinematicFrame = 0;

    const format = (seconds: number) => {
      const minutes = Math.floor(seconds / 60);
      const remainder = Math.floor(seconds % 60);
      return `${minutes}:${String(remainder).padStart(2, "0")}`;
    };

    const setChapter = (index: number) => {
      if (index < 0 || !chapters[index]) return;
      activeChapter = index;
      chapterLinks.forEach((link, linkIndex) => link.toggleAttribute("aria-current", linkIndex === index));
      if (currentChapter) currentChapter.textContent = `Chapter ${["I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX"][index]} · ${chapters[index].title}`;
    };

    const beatForTime = (seconds: number) => {
      let index = 0;
      beats.forEach((beat: { start: number }, beatIndex: number) => {
        if (seconds >= beat.start) index = beatIndex;
      });
      return index;
    };

    const setBeat = (index: number, source: "audio" | "scroll" | "restore" = "scroll") => {
      if (index < 0 || !beats[index]) return;
      const changed = activeBeat !== index;
      activeBeat = index;
      beatElements.forEach((element, elementIndex) => {
        element.classList.toggle("is-current-beat", elementIndex === index);
        element.toggleAttribute("aria-current", elementIndex === index);
      });
      setChapter(Number(beats[index].chapter) - 1);

      if (source === "audio" && followNarration && changed && lastAutoScrolledBeat !== index) {
        lastAutoScrolledBeat = index;
        suppressScrollSeekUntil = Date.now() + 1500;
        beatElements[index]?.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    };

    const updateAudioPosition = () => {
      if (!audio || !seek || !currentTime) return;
      seek.value = String(audio.currentTime);
      seek.style.setProperty("--played", `${(audio.currentTime / Number(seek.max)) * 100}%`);
      currentTime.textContent = format(audio.currentTime);
    };

    const updatePlayState = () => {
      if (!audio) return;
      const playing = !audio.paused;
      document.body.classList.toggle("is-listening", playing);
      if (playIcon) playIcon.textContent = playing ? "Ⅱ" : "▶";
      dockPlay?.setAttribute("aria-label", playing ? "Pause narration" : "Play narration");
    };

    const togglePlayback = async () => {
      if (!audio) return;
      if (audio.paused) {
        try {
          await audio.play();
          if (followNarration) {
            lastAutoScrolledBeat = -1;
            setBeat(beatForTime(audio.currentTime), "audio");
          }
        } catch {
          return;
        }
      } else {
        audio.pause();
      }
      updatePlayState();
    };

    playButtons.forEach((button) => button.addEventListener("click", togglePlayback));
    audio?.addEventListener("play", updatePlayState);
    audio?.addEventListener("pause", updatePlayState);
    audio?.addEventListener("ended", updatePlayState);

    audio?.addEventListener("timeupdate", () => {
      updateAudioPosition();
      setBeat(beatForTime(audio.currentTime), "audio");
      try {
        localStorage.setItem("scaleofus-wind-progress", String(audio.currentTime));
      } catch {}
    });

    seek?.addEventListener("input", () => {
      if (!audio) return;
      audio.currentTime = Number(seek.value);
      lastAutoScrolledBeat = -1;
      updateAudioPosition();
      setBeat(beatForTime(audio.currentTime), "audio");
    });

    chapterLinks.forEach((link, index) => {
      link.addEventListener("click", () => {
        if (audio) {
          audio.currentTime = Number(link.dataset.start ?? 0);
          updateAudioPosition();
        }
        setChapter(index);
        const targetBeat = beats.findIndex((beat: { chapter: number }) => beat.chapter === index + 1);
        if (targetBeat >= 0) setBeat(targetBeat, "scroll");
      });
    });

    follow?.addEventListener("click", () => {
      followNarration = !followNarration;
      follow.setAttribute("aria-pressed", String(followNarration));
      lastAutoScrolledBeat = -1;
      if (followNarration && audio) setBeat(beatForTime(audio.currentTime), "audio");
    });

    collapse?.addEventListener("click", () => {
      const collapsed = dock?.classList.toggle("is-collapsed") ?? false;
      collapse.setAttribute("aria-expanded", String(!collapsed));
      collapse.setAttribute("aria-label", collapsed ? "Expand audio player" : "Minimize audio player");
      collapse.textContent = collapsed ? "⌃" : "⌄";
    });

    const chapterObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = chapterElements.indexOf(entry.target as HTMLElement);
            if (!audio || audio.paused) setChapter(index);
          }
        });
      },
      { rootMargin: "-28% 0px -62%", threshold: 0 },
    );
    chapterElements.forEach((chapter) => chapterObserver.observe(chapter));

    const beatObserver = new IntersectionObserver(
      (entries) => entries.forEach((entry) => entry.target.classList.toggle("is-seen", entry.isIntersecting)),
      { rootMargin: "-10% 0px -10%", threshold: 0.16 },
    );
    beatElements.forEach((beat) => beatObserver.observe(beat));

    const markUserScrollIntent = () => {
      lastUserScrollIntent = Date.now();
    };
    addEventListener("wheel", markUserScrollIntent, { passive: true });
    addEventListener("touchstart", markUserScrollIntent, { passive: true });
    addEventListener("pointerdown", markUserScrollIntent, { passive: true });
    addEventListener("keydown", (event) => {
      if (["ArrowDown", "ArrowUp", "PageDown", "PageUp", "Home", "End", " "].includes(event.key)) markUserScrollIntent();
    });

    const syncAudioFromViewport = () => {
      scrollSeekFrame = 0;
      if (!audio || Date.now() < suppressScrollSeekUntil || Date.now() - lastUserScrollIntent > 1200) return;
      const center = innerHeight * 0.5;
      let closest = -1;
      let closestDistance = Number.POSITIVE_INFINITY;
      beatElements.forEach((element, index) => {
        const rect = element.getBoundingClientRect();
        const distance = Math.abs(rect.top + rect.height * 0.5 - center);
        if (distance < closestDistance) {
          closestDistance = distance;
          closest = index;
        }
      });
      if (closest < 0 || closest === activeBeat) return;
      audio.currentTime = Number(beats[closest].start);
      lastAutoScrolledBeat = closest;
      updateAudioPosition();
      setBeat(closest, "scroll");
    };

    const updateReadingProgress = () => {
      if (!readingProgress) return;
      const available = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = available > 0 ? window.scrollY / available : 0;
      readingProgress.style.transform = `scaleX(${Math.min(1, Math.max(0, ratio))})`;
      document.documentElement.style.setProperty("--nav-cloud-lift", `${ratio * -62}px`);
      document.documentElement.style.setProperty("--nav-cloud-drift", `${Math.sin(ratio * Math.PI * 5) * 7}px`);
    };

    const updateCinematicMotion = () => {
      cinematicFrame = 0;
      cinematicFrames.forEach((frame, index) => {
        const rect = frame.getBoundingClientRect();
        if (rect.bottom < -innerHeight * 0.35 || rect.top > innerHeight * 1.35) return;
        const progress = Math.min(1, Math.max(0, (innerHeight - rect.top) / (innerHeight + rect.height)));
        const centered = progress - 0.5;
        const direction = index % 2 === 0 ? 1 : -1;
        frame.style.setProperty("--motion-x", `${centered * direction * 24}px`);
        frame.style.setProperty("--motion-y", `${centered * -15}px`);
        frame.style.setProperty("--image-shift", `${centered * -9}px`);
      });
    };

    const requestCinematicMotion = () => {
      if (!cinematicFrame) cinematicFrame = requestAnimationFrame(updateCinematicMotion);
    };
    addEventListener("scroll", () => {
      updateReadingProgress();
      if (!scrollSeekFrame) scrollSeekFrame = requestAnimationFrame(syncAudioFromViewport);
      requestCinematicMotion();
    }, { passive: true });
    addEventListener("resize", requestCinematicMotion, { passive: true });
    updateReadingProgress();
    updateCinematicMotion();

    addEventListener("pointermove", (event) => {
      document.documentElement.style.setProperty("--pointer-x", `${event.clientX / innerWidth - 0.5}`);
      document.documentElement.style.setProperty("--pointer-y", `${event.clientY / innerHeight - 0.5}`);
    }, { passive: true });

    try {
      const saved = Number(localStorage.getItem("scaleofus-wind-progress"));
      if (audio && seek && Number.isFinite(saved) && saved > 5 && saved < Number(seek.max) - 5) {
        audio.currentTime = saved;
        updateAudioPosition();
        setBeat(beatForTime(saved), "restore");
      }
    } catch {}

    if (location.hash.startsWith("#beat-")) {
      const beatNumber = Number(location.hash.replace("#beat-", ""));
      const beatIndex = beats.findIndex((beat: { number: number }) => beat.number === beatNumber);
      if (beatIndex >= 0 && audio) {
        audio.currentTime = Number(beats[beatIndex].start);
        updateAudioPosition();
        setBeat(beatIndex, "restore");
      }
    } else if (location.hash.startsWith("#chapter-")) {
      const chapterIndex = chapters.findIndex((chapter: { id: string }) => `#${chapter.id}` === location.hash);
      const beatIndex = beats.findIndex((beat: { chapter: number }) => beat.chapter === chapterIndex + 1);
      if (chapterIndex >= 0 && beatIndex >= 0 && audio) {
        audio.currentTime = Number(beats[beatIndex].start);
        updateAudioPosition();
        setBeat(beatIndex, "restore");
      }
    }
  </script>
</Base>
